@page
@model FinTech.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <h1 class="display-4 text-primary mb-4">🚀 Dashboard</h1>
                    <p class="lead text-muted">
                        Hoşgeldiniz! Giriş işleminiz başarıyla tamamlandı.
                    </p>
                    <hr class="my-4">
                    <div class="alert alert-info">
                        <strong>Bilgi:</strong> Burası bir placeholder (yer tutucu) sayfadır. 
                        Diğer ekipler dashboard arayüzünü buraya entegre edecektir.
                    </div>
                    <p class="mt-4">
                        <a href="#" class="btn btn-outline-primary">Profil Ayarları</a>
                        <a href="#" class="btn btn-primary">Raporlar</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
