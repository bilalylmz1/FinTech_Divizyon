@page
@model FinTech.Pages.Help.HelpCenterModel
@{
    ViewData["Title"] = "Yardım & Destek Merkezi";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - İnteraktif Kredi</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/help_center.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <!-- Top Header (Fixed) -->
    <header class="dashboard-header">
        <div class="header-left">
            <button id="menuToggle" class="menu-toggle-btn">
                <img src="/img/dashboard/icon-menu.svg" alt="Menü" />
            </button>
            <img src="/img/dashboard/logo.svg" alt="İnteraktif Kredi" class="header-logo" />
        </div>
        <div class="user-mini-profile" style="font-size: 14px; gap:8px;">
            <div class="user-avatar" style="width:32px; height:32px; font-size:12px;">MG</div>
            <span class="user-name">Mustafa Gümüş</span>
        </div>
    </header>

    <div class="dashboard-wrapper">
        <!-- Sidebar (Fixed Left) -->
        <aside class="dashboard-sidebar" id="sidebar">
            <nav class="sidebar-menu">
                <div class="menu-category">Ana Menü</div>
                <a href="/" class="menu-item">
                    <i class="fa-solid fa-house"></i> <span>Dashboard</span>
                </a>
                <a href="#" class="menu-item">
                    <i class="fa-solid fa-chart-pie"></i> <span>Rapor Detayları</span>
                </a>

                <div class="menu-category">Hesap</div>
                <a href="#" class="menu-item">
                    <i class="fa-solid fa-user-gear"></i> <span>Profil & Ayarlar</span>
                </a>
                <a href="/Help/HelpCenter" class="menu-item active">
                    <i class="fa-solid fa-circle-question"></i> <span>Yardım & Destek</span>
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content" id="mainContent">
            
            <!-- Breadcrumb -->
            <nav class="breadcrumb">
                <a href="/" class="breadcrumb__item">Dashboard</a>
                <i class="fa-solid fa-chevron-right breadcrumb__separator"></i>
                <span class="breadcrumb__item breadcrumb__item--active">Yardım & Destek Merkezi</span>
            </nav>

            <!-- Hero Section with Search -->
            <div class="help_hero">
                <h1 class="help_hero__title">Size nasıl yardımcı olabiliriz?</h1>
                <p class="help_hero__subtitle">Sorularınızın yanıtlarını arayın veya aşağıdaki kategorilere göz atın</p>
                
                <div class="help_search">
                    <div class="help_search__wrapper">
                        <i class="fa-solid fa-magnifying-glass help_search__icon"></i>
                        <input 
                            type="text" 
                            class="help_search__input" 
                            id="help_search_input"
                            placeholder="Soru veya konu ara..." 
                            autocomplete="off"
                        />
                        <button class="help_search__button" id="help_search_btn">
                            Ara
                        </button>
                    </div>
                </div>
            </div>

            <!-- Kategori Kartları -->
            <div class="help_categories">
                <!-- SSS / Rehber -->
                <a href="/Help/Faq" class="help_card">
                    <div class="help_card__icon help_card__icon--blue">
                        <i class="fa-solid fa-book-open"></i>
                    </div>
                    <h3 class="help_card__title">SSS / Rehber</h3>
                    <p class="help_card__description">
                        Sıkça sorulan sorular ve kullanım kılavuzları
                    </p>
                    <span class="help_card__arrow">
                        <i class="fa-solid fa-arrow-right"></i> İncele
                    </span>
                </a>

                <!-- Kredi Teklifleri -->
                <a href="#" class="help_card">
                    <div class="help_card__icon help_card__icon--green">
                        <i class="fa-solid fa-hand-holding-dollar"></i>
                    </div>
                    <h3 class="help_card__title">Kredi Teklifleri</h3>
                    <p class="help_card__description">
                        Size özel hazırlanmış kredi fırsatları
                    </p>
                    <span class="help_card__arrow">
                        <i class="fa-solid fa-arrow-right"></i> İncele
                    </span>
                </a>

                <!-- İletişim & Destek -->
                <a href="#" class="help_card">
                    <div class="help_card__icon help_card__icon--purple">
                        <i class="fa-solid fa-headset"></i>
                    </div>
                    <h3 class="help_card__title">İletişim & Destek</h3>
                    <p class="help_card__description">
                        Canlı destek ve müşteri hizmetleri
                    </p>
                    <span class="help_card__arrow">
                        <i class="fa-solid fa-arrow-right"></i> İncele
                    </span>
                </a>
            </div>

            <!-- Popüler Sorular -->
            <div class="popular_questions">
                <div class="popular_questions__header">
                    <h3 class="popular_questions__title">
                        <i class="fa-solid fa-fire"></i>
                        Popüler Sorular
                    </h3>
                    <a href="/Help/Faq" class="popular_questions__see_all">
                        Tümünü Gör <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>

                <ul class="popular_questions__list" id="popular_questions_list">
                    <!-- JavaScript ile doldurulacak -->
                </ul>
            </div>

            <!-- İletişim Bandı -->
            <div class="contact_banner">
                <div class="contact_banner__content">
                    <div class="contact_banner__icon">
                        <i class="fa-solid fa-comments"></i>
                    </div>
                    <div class="contact_banner__text">
                        <h4>Aradığınızı bulamadınız mı?</h4>
                        <p>Uzman ekibimiz size yardımcı olmaktan mutluluk duyar</p>
                    </div>
                </div>
                <a href="#" class="contact_banner__button">
                    <i class="fa-solid fa-paper-plane"></i> Destek Talebi Oluştur
                </a>
            </div>

        </main>
    </div>

    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/pages/help_center.js"></script>
    <script>
        // Sidebar Toggle
        var $menu_toggle = $('#menuToggle');
        var $sidebar = $('#sidebar');
        var $main_content = $('#mainContent');

        if ($menu_toggle.length) {
            $menu_toggle.on('click', function() {
                $sidebar.toggleClass('closed');
                $main_content.toggleClass('full-width');
            });
        }
    </script>
</body>
</html>

