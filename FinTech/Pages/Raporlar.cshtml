@page
@model FinTech.Pages.RaporlarModel
@{
    ViewData["Title"] = "Raporlar";
}

<div class="raporlar">
    <div class="raporlar__container">
        
        <!-- Header -->
        <header class="raporlar__header">
            <div class="raporlar__header_left">
                <h1 class="raporlar__title">Rapor Listesi</h1>
                <p class="raporlar__subtitle">Tüm kredi güven raporlarınızı görüntüleyin</p>
            </div>
            <div class="raporlar__header_right">
                <button class="btn btn_secondary btn--small" id="refresh_reports_btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="23 4 23 10 17 10"></polyline>
                        <polyline points="1 20 1 14 7 14"></polyline>
                        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                    </svg>
                    Yenile
                </button>
            </div>
        </header>
        
        <!-- Rapor Listesi Section -->
        <section class="raporlar__section">
            <div class="raporlar__section_header">
                <h2 class="raporlar__section_title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                    </svg>
                    Kredi Güven Raporları
                </h2>
                <span class="raporlar__count" id="reports_count">0 rapor</span>
            </div>
            
            <!-- Loading State -->
            <div class="raporlar__loading" id="reports_loading">
                <div class="loading_spinner"></div>
                <p>Raporlar yükleniyor...</p>
            </div>
            
            <!-- Reports Grid -->
            <div class="raporlar__grid" id="reports_list" style="display: none;">
                <!-- Raporlar JavaScript ile dinamik olarak eklenecek -->
            </div>
            
            <!-- Error State -->
            <div class="raporlar__error" id="reports_error" style="display: none;">
                <div class="error_icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                </div>
                <p class="error_message" id="reports_error_message">Raporlar yüklenirken bir hata oluştu.</p>
                <button class="btn btn_secondary btn--small" id="retry_reports_btn">Tekrar Dene</button>
            </div>
            
            <!-- Empty State -->
            <div class="raporlar__empty" id="reports_empty" style="display: none;">
                <div class="empty_icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                </div>
                <h3>Henüz rapor bulunmuyor</h3>
                <p>Kredi güven raporunuz oluşturulduğunda burada görünecektir.</p>
            </div>
        </section>
        
        <!-- Faturalar Section -->
        <section class="raporlar__section">
            <div class="raporlar__section_header">
                <h2 class="raporlar__section_title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                        <line x1="1" y1="10" x2="23" y2="10"></line>
                    </svg>
                    Faturalar
                </h2>
            </div>
            
            <div class="raporlar__loading" id="invoices_loading">
                <div class="loading_spinner"></div>
                <p>Faturalar yükleniyor...</p>
            </div>
            
            <div class="raporlar__grid raporlar__grid--invoices" id="invoices_list" style="display: none;">
                <!-- Faturalar JavaScript ile dinamik olarak eklenecek -->
            </div>
        </section>
        
        <!-- Kredi Teklifleri Section -->
        <section class="raporlar__section">
            <div class="raporlar__section_header">
                <h2 class="raporlar__section_title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="1" x2="12" y2="23"></line>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                    </svg>
                    Kredi Teklifleri
                </h2>
            </div>
            
            <div class="raporlar__loading" id="offers_loading">
                <div class="loading_spinner"></div>
                <p>Teklifler yükleniyor...</p>
            </div>
            
            <div class="raporlar__grid raporlar__grid--offers" id="offers_list" style="display: none;">
                <!-- Kredi teklifleri JavaScript ile dinamik olarak eklenecek -->
            </div>
        </section>
        
    </div>
</div>

@section Scripts {
    <script src="~/js/helpers/api_client.js" asp-append-version="true"></script>
    <script src="~/js/raporlar.js" asp-append-version="true"></script>
}

