<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="İnteraktif Kredi - Web Şube 2.0" />
    <title>@ViewData["Title"] - İnteraktif Kredi</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    
    <!-- Poppins Font (Google Fonts) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Main CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinTech.styles.css" asp-append-version="true" />
    
    <!-- Sidebar State Script - Sayfa yüklenmeden önce çalışır -->
    <script>
        // Sayfa yüklenmeden önce sidebar durumunu kontrol et
        // Bu sayede animasyon olmadan doğru durumda başlar
        (function() {
            var isCollapsed = localStorage.getItem('sidebar_collapsed') === 'true';
            if (isCollapsed) {
                // Body'ye class ekleyerek CSS'in doğru durumda başlamasını sağla
                document.documentElement.classList.add('sidebar-collapsed-initial');
            }
        })();
    </script>
    
    <style>
        /* Sayfa yüklenirken transition'ı devre dışı bırak */
        html.sidebar-collapsed-initial .sidebar {
            width: var(--sidebar-collapsed-width) !important;
            transition: none !important;
        }
        html.sidebar-collapsed-initial .sidebar .sidebar__logo_text,
        html.sidebar-collapsed-initial .sidebar .sidebar__link_text {
            opacity: 0 !important;
            width: 0 !important;
            transition: none !important;
        }
        html.sidebar-collapsed-initial .sidebar .sidebar__link {
            justify-content: center !important;
            padding: var(--spacing-3) !important;
        }
        html.sidebar-collapsed-initial .sidebar .sidebar__logout {
            justify-content: center !important;
            padding: var(--spacing-3) !important;
        }
        html.sidebar-collapsed-initial .sidebar .sidebar__header {
            justify-content: center !important;
            padding: var(--spacing-4) !important;
        }
        html.sidebar-collapsed-initial .sidebar .sidebar__brand {
            justify-content: center !important;
        }
        html.sidebar-collapsed-initial .sidebar .sidebar__toggle {
            position: absolute !important;
            right: -12px !important;
            top: 50% !important;
            transform: translateY(-50%) !important;
        }
        html.sidebar-collapsed-initial .sidebar .sidebar__toggle svg {
            transform: rotate(180deg) !important;
        }
        html.sidebar-collapsed-initial .sidebar .sidebar__divider {
            margin: var(--spacing-4) var(--spacing-3) !important;
        }
        html.sidebar-collapsed-initial .main_wrapper {
            margin-left: var(--sidebar-collapsed-width) !important;
            width: calc(100% - var(--sidebar-collapsed-width)) !important;
            transition: none !important;
        }
    </style>
</head>
<body>
    <div class="page_wrapper">
        
        <!-- Sidebar Overlay (Mobile) -->
        <div class="sidebar__overlay" id="sidebar_overlay"></div>
        
        <!-- Left Sidebar -->
        <aside class="sidebar" id="sidebar">
            <!-- Sidebar Header (Logo) -->
            <div class="sidebar__header">
                <a href="/" class="sidebar__brand">
                    <div class="sidebar__logo_icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div class="sidebar__logo_text">
                        <span class="sidebar__logo_title">interaktif</span>
                        <span class="sidebar__logo_subtitle">kredi</span>
                    </div>
                </a>
                
                <!-- Desktop Toggle Button -->
                <button class="sidebar__toggle" id="sidebar_collapse_toggle" aria-label="Menüyü daralt/genişlet" title="Menüyü daralt/genişlet">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                </button>
                
                <!-- Mobile Close Button -->
                <button class="sidebar__close" id="sidebar_close" aria-label="Menüyü kapat">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            
            <!-- Sidebar Menu -->
            <nav class="sidebar__nav">
                <ul class="sidebar__menu">
                    <li class="sidebar__item">
                        <a asp-page="/Dashboard" class="sidebar__link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Dashboard" ? "sidebar__link--active" : "")">
                            <span class="sidebar__link_icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="7" height="9"></rect>
                                    <rect x="14" y="3" width="7" height="5"></rect>
                                    <rect x="14" y="12" width="7" height="9"></rect>
                                    <rect x="3" y="16" width="7" height="5"></rect>
                                </svg>
                            </span>
                            <span class="sidebar__link_text">Dashboard</span>
                            <span class="sidebar__tooltip">Dashboard</span>
                        </a>
                    </li>
                    <li class="sidebar__item">
                        <a asp-page="/Raporlar" class="sidebar__link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Raporlar" ? "sidebar__link--active" : "")">
                            <span class="sidebar__link_icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14 2 14 8 20 8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                </svg>
                            </span>
                            <span class="sidebar__link_text">Raporlar</span>
                            <span class="sidebar__tooltip">Raporlar</span>
                        </a>
                    </li>
                    <li class="sidebar__item">
                        <a asp-page="/KrediBasvuru" class="sidebar__link">
                            <span class="sidebar__link_icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="1" x2="12" y2="23"></line>
                                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                                </svg>
                            </span>
                            <span class="sidebar__link_text">Kredi Başvurusu</span>
                            <span class="sidebar__tooltip">Kredi Başvurusu</span>
                        </a>
                    </li>
                    <li class="sidebar__item">
                        <a asp-page="/Profil" class="sidebar__link">
                            <span class="sidebar__link_icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                            </span>
                            <span class="sidebar__link_text">Profil</span>
                            <span class="sidebar__tooltip">Profil</span>
                        </a>
                    </li>
                </ul>
                
                <!-- Sidebar Divider -->
                <div class="sidebar__divider"></div>
                
                <!-- Secondary Menu -->
                <ul class="sidebar__menu sidebar__menu--secondary">
                    <li class="sidebar__item">
                        <a href="#" class="sidebar__link">
                            <span class="sidebar__link_icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="3"></circle>
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                                </svg>
                            </span>
                            <span class="sidebar__link_text">Ayarlar</span>
                            <span class="sidebar__tooltip">Ayarlar</span>
                        </a>
                    </li>
                    <li class="sidebar__item">
                        <a href="#" class="sidebar__link">
                            <span class="sidebar__link_icon">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                </svg>
                            </span>
                            <span class="sidebar__link_text">Yardım</span>
                            <span class="sidebar__tooltip">Yardım</span>
                        </a>
                    </li>
                </ul>
            </nav>
            
            <!-- Sidebar Footer -->
            <div class="sidebar__footer">
                <a href="#" class="sidebar__logout">
                    <span class="sidebar__link_icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                            <polyline points="16 17 21 12 16 7"></polyline>
                            <line x1="21" y1="12" x2="9" y2="12"></line>
                        </svg>
                    </span>
                    <span class="sidebar__link_text">Çıkış Yap</span>
                    <span class="sidebar__tooltip">Çıkış Yap</span>
                </a>
            </div>
        </aside>
        
        <!-- Main Content Area -->
        <div class="main_wrapper" id="main_wrapper">
            <!-- Top Header Bar -->
            <header class="top_header">
                <div class="top_header__left">
                    <!-- Sidebar Toggle Button (Mobile) -->
                    <button class="sidebar_toggle" id="sidebar_toggle" aria-label="Menüyü aç/kapat">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="3" y1="12" x2="21" y2="12"></line>
                            <line x1="3" y1="6" x2="21" y2="6"></line>
                            <line x1="3" y1="18" x2="21" y2="18"></line>
                        </svg>
                    </button>
                    
                    <!-- Mobile Logo -->
                    <a href="/" class="top_header__brand">
                        <div class="top_header__logo_icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                        <div class="top_header__logo_text">
                            <span class="top_header__logo_title">interaktif</span>
                            <span class="top_header__logo_subtitle">kredi</span>
                        </div>
                    </a>
                </div>
                
                <div class="top_header__right">
                    <!-- Notifications -->
                    <button class="top_header__icon_btn" aria-label="Bildirimler">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                        </svg>
                        <span class="top_header__badge">3</span>
                    </button>
                    
                    <!-- User Profile -->
                    <div class="top_header__user" id="user_dropdown_toggle">
                        <div class="top_header__user_info">
                            <span class="top_header__user_name">Mustafa Gümüş</span>
                            <span class="top_header__user_role">Bireysel</span>
                        </div>
                        <div class="top_header__avatar">MG</div>
                        <svg class="top_header__dropdown_icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                </div>
            </header>
            
            <!-- Page Content -->
            <main class="page_content">
                @RenderBody()
            </main>
        </div>
    </div>
    
    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    
    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
